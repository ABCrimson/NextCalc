{
  "name": "@nextcalc/plot-engine",
  "version": "1.5.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./renderers": {
      "types": "./src/renderers/index.ts",
      "default": "./src/renderers/index.ts"
    },
    "./sampling": {
      "types": "./src/sampling/index.ts",
      "default": "./src/sampling/index.ts"
    },
    "./export": {
      "types": "./src/export/index.ts",
      "default": "./src/export/index.ts"
    },
    "./controls": {
      "types": "./src/controls/index.ts",
      "default": "./src/controls/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "three": "0.185.1"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/three": "0.185.1",
    "@webgpu/types": "0.1.71",
    "fast-check": "4.9.0",
    "typescript": "6.0.3",
    "vitest": "5.0.0-beta.6"
  }
}
