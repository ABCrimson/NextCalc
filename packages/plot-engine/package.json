{
  "name": "@nextcalc/plot-engine",
  "version": "1.2.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./renderers": {
      "types": "./src/renderers/index.ts",
      "default": "./src/renderers/index.ts"
    },
    "./sampling": {
      "types": "./src/sampling/index.ts",
      "default": "./src/sampling/index.ts"
    },
    "./export": {
      "types": "./src/export/index.ts",
      "default": "./src/export/index.ts"
    },
    "./controls": {
      "types": "./src/controls/index.ts",
      "default": "./src/controls/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@nextcalc/math-engine": "workspace:*",
    "d3": "7.9.0",
    "three": "0.183.2"
  },
  "devDependencies": {
    "@types/d3": "7.4.3",
    "@types/node": "25.3.3",
    "@types/three": "0.183.1",
    "fast-check": "4.5.3",
    "typedoc": "^0.28.17",
    "typescript": "6.0.0-dev.20260309",
    "vitest": "4.1.0-beta.5"
  }
}
