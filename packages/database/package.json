{
  "name": "@nextcalc/database",
  "version": "1.5.2",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./models": {
      "types": "./src/generated/prisma/models.ts",
      "import": "./src/generated/prisma/models.ts",
      "default": "./src/generated/prisma/models.ts"
    }
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:samples": "tsx scripts/seed-samples.ts",
    "db:promote-admin": "tsx scripts/promote-admin.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "1.1.0",
    "@prisma/adapter-neon": "7.9.0-dev.19",
    "@prisma/client": "7.9.0-dev.19"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "dotenv": "17.4.2",
    "prisma": "7.9.0-dev.19",
    "tsx": "4.23.1",
    "typescript": "7.1.0-dev.20260708.3"
  }
}
