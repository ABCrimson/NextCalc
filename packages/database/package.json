{
  "name": "@nextcalc/database",
  "version": "1.2.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./models": {
      "types": "./src/generated/prisma/models.ts",
      "import": "./src/generated/prisma/models.ts",
      "default": "./src/generated/prisma/models.ts"
    }
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@neondatabase/serverless": "1.0.2",
    "@prisma/adapter-neon": "7.9.0-dev.13",
    "@prisma/client": "7.9.0-dev.13"
  },
  "devDependencies": {
    "dotenv": "17.3.1",
    "prisma": "7.9.0-dev.13",
    "tsx": "4.21.0",
    "typescript": "6.0.0-dev.20260301"
  }
}
