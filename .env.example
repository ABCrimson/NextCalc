# NextCalc Pro Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================================
# DATABASE (Neon PostgreSQL)
# ============================================================================

# PostgreSQL connection string with pooling (for API routes and serverless functions)
DATABASE_URL="postgresql://user:password@host.neon.tech/nextcalc?sslmode=require&pgbouncer=true"

# Direct PostgreSQL connection (for migrations only)
DIRECT_DATABASE_URL="postgresql://user:password@host.neon.tech/nextcalc?sslmode=require"

# ============================================================================
# AUTHENTICATION (NextAuth.js v5)
# ============================================================================

# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl"

# Next.js URL (for OAuth callbacks)
NEXTAUTH_URL="http://localhost:3005"

# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth
# Get credentials from: https://github.com/settings/developers
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ============================================================================
# REDIS (Upstash)
# ============================================================================

# Upstash Redis REST API (used by @upstash/redis)
# Get credentials from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL="https://your-endpoint.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ============================================================================
# NEXT.JS
# ============================================================================

# Environment (development, production, test)
NODE_ENV="development"

# Application version (auto-populated from package.json)
npm_package_version="0.1.0"

# ============================================================================
# OPTIONAL: MONITORING & OBSERVABILITY
# ============================================================================

# Sentry DSN (for error tracking)
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""

# PostHog API Key (for analytics)
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST=""

# Vercel Analytics (automatically enabled on Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""

# ============================================================================
# OPTIONAL: FILE STORAGE (for worksheet images/attachments)
# ============================================================================

# AWS S3 (or S3-compatible like Cloudflare R2)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET=""

# Cloudflare R2
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET=""

# ============================================================================
# OPTIONAL: EMAIL (for notifications)
# ============================================================================

# SendGrid
# SENDGRID_API_KEY=""
# SENDGRID_FROM_EMAIL="noreply@nextcalc.com"

# Resend
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="noreply@nextcalc.com"

# ============================================================================
# OPTIONAL: RATE LIMITING
# ============================================================================

# Override default rate limits
# RATE_LIMIT_AUTHENTICATED=100  # Requests per minute for authenticated users
# RATE_LIMIT_ANONYMOUS=1000     # Requests per minute per IP for anonymous users

# ============================================================================
# OPTIONAL: FEATURE FLAGS
# ============================================================================

# Enable/disable features
# FEATURE_FORUM_ENABLED="true"
# FEATURE_PUBLIC_GALLERY_ENABLED="true"
# FEATURE_COLLABORATION_ENABLED="true"

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================

# Disable HTTPS check in development
# NEXTAUTH_URL_INTERNAL="http://localhost:3000"

# Enable detailed query logging
# PRISMA_LOG_LEVEL="query,info,warn,error"

# Disable telemetry
# NEXT_TELEMETRY_DISABLED="1"
