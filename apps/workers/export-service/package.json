{
  "name": "@nextcalc/export-service",
  "version": "1.2.1",
  "private": true,
  "description": "Export service for NextCalc Pro - converts LaTeX expressions to PDF, PNG, and SVG formats",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@cf-wasm/resvg": "0.3.3",
    "hono": "4.12.3",
    "katex": "0.16.33",
    "modern-pdf-lib": "0.15.1",
    "zod": "4.4.0-canary.20260125T215152"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@cloudflare/workers-types": "4.20260307.1",
    "@types/node": "25.3.5",
    "typescript": "6.0.0-dev.20260301",
    "vitest": "4.1.0-beta.5",
    "wrangler": "4.71.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
