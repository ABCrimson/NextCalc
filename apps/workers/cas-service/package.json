{
  "name": "@nextcalc/cas-service",
  "version": "1.2.1",
  "private": true,
  "description": "Computer Algebra System microservice for NextCalc Pro - symbolic math operations on Cloudflare Edge",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "hono": "4.12.3",
    "mathjs": "15.1.1",
    "zod": "4.4.0-canary.20260125T215152"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@cloudflare/workers-types": "4.20260329.1",
    "@types/node": "25.5.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2",
    "wrangler": "4.78.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
