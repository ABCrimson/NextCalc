{
  "name": "@nextcalc/cas-service",
  "version": "1.3.0",
  "private": true,
  "description": "Computer Algebra System microservice for NextCalc Pro - symbolic math operations on Cloudflare Edge",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:fast": "tsgo --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "hono": "4.12.27",
    "mathjs": "15.2.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@cloudflare/workers-types": "4.20260629.1",
    "@types/node": "26.0.1",
    "typescript": "6.0.3",
    "vitest": "5.0.0-beta.5",
    "wrangler": "4.105.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
