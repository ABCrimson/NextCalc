{
  "name": "@nextcalc/rate-limiter",
  "version": "1.2.1",
  "private": true,
  "description": "Rate limiting microservice for NextCalc Pro - enforces API quotas using Cloudflare KV",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "hono": "4.12.3",
    "zod": "4.4.0-canary.20260125T215152"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@cloudflare/workers-types": "4.20260413.1",
    "@types/node": "25.6.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4",
    "wrangler": "4.81.1"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
