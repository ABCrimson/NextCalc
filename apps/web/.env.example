# NextCalc Pro - Environment Variables Configuration
# ==================================================
# Copy this file to .env.local and fill in your actual values
# IMPORTANT: Never commit .env.local to version control!

# ======================
# Database Configuration
# ======================
# PostgreSQL connection string from Neon (https://neon.tech)
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
# See docs/DATABASE_SETUP.md for detailed setup instructions
DATABASE_URL="postgresql://user:password@host.neon.tech:5432/nextcalc?sslmode=require"

# Direct database URL (same as DATABASE_URL for Neon)
DIRECT_DATABASE_URL="postgresql://user:password@host.neon.tech:5432/nextcalc?sslmode=require"

# ======================
# NextAuth Configuration
# ======================
# Generate a secure secret with: openssl rand -base64 32
# This is required for session encryption and CSRF protection
NEXTAUTH_SECRET="your-super-secret-key-here-generate-with-openssl-min-32-chars"

# Your application URL
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ======================
# Google OAuth
# ======================
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# 1. Create a new "OAuth 2.0 Client ID"
# 2. Add authorized redirect URI: http://localhost:3000/api/auth/callback/google
# 3. For production, also add: https://your-domain.com/api/auth/callback/google
# See docs/OAUTH_SETUP.md for detailed instructions
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ======================
# GitHub OAuth
# ======================
# Create OAuth app at: https://github.com/settings/developers
# 1. Click "New OAuth App"
# 2. Set Authorization callback URL: http://localhost:3000/api/auth/callback/github
# 3. For production, create a separate app with: https://your-domain.com/api/auth/callback/github
# See docs/OAUTH_SETUP.md for detailed instructions
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"

# ======================
# Redis (Optional - for rate limiting and caching)
# ======================
# Get these from Upstash (https://upstash.com)
# Required for production rate limiting and session storage
# Free tier available at https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ======================
# Application Configuration
# ======================
# Node environment (development, production, test)
NODE_ENV="development"

# Port for development server (default: 3000)
PORT="3000"

# API Configuration (if using external GraphQL API)
NEXT_PUBLIC_API_URL="http://localhost:4000/graphql"

# ======================
# Feature Flags
# ======================
# Enable/disable features
NEXT_PUBLIC_ENABLE_PLOT_ENGINE="true"
NEXT_PUBLIC_ENABLE_WORKSHEETS="true"
NEXT_PUBLIC_ENABLE_FORUM="false"
NEXT_PUBLIC_ENABLE_LATEX="true"
NEXT_PUBLIC_ENABLE_PLOTS="true"
NEXT_PUBLIC_ENABLE_HISTORY="true"

# ======================
# Monitoring & Analytics (Optional)
# ======================
# Google Analytics Measurement ID
# Get from: https://analytics.google.com/
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Sentry Error Tracking
# Get from: https://sentry.io/
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""

# Vercel Analytics (automatically enabled on Vercel)
# No configuration needed if deploying to Vercel

# ======================
# Development Tools (Optional)
# ======================
# Enable Next.js telemetry (set to 0 to disable)
# NEXT_TELEMETRY_DISABLED="0"

# Enable React strict mode for development
# NEXT_PUBLIC_ENABLE_STRICT_MODE="true"

# ======================
# Security (Production)
# ======================
# Content Security Policy
# Customize based on your needs
# CSP_HEADER="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval';"

# ======================
# Notes
# ======================
# - All variables starting with NEXT_PUBLIC_ are exposed to the browser
# - Keep sensitive keys (secrets, tokens) without NEXT_PUBLIC_ prefix
# - For production deployment, set these in your hosting platform (Vercel, etc.)
# - See docs/ folder for detailed setup guides
