{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "DATABASE_URL",
        "DIRECT_DATABASE_URL",
        "AUTH_SECRET",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "NEXT_PUBLIC_APP_URL",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_DOMAIN",
        "NEXT_PUBLIC_PRODUCTION_URL",
        "NEXT_PUBLIC_ENABLE_PLOT_ENGINE",
        "NEXT_PUBLIC_ENABLE_WORKSHEETS",
        "NEXT_PUBLIC_ENABLE_FORUM",
        "NEXT_PUBLIC_ENABLE_LATEX",
        "NEXT_PUBLIC_ENABLE_PLOTS",
        "NEXT_PUBLIC_ENABLE_HISTORY",
        "ENABLE_EXPERIMENTAL_COREPACK",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_DSN",
        "NEXT_PUBLIC_SENTRY_DSN"
      ],
      "outputs": [".next/**", "dist/**", "build/**"],
      "outputLogs": "new-only"
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "outputLogs": "new-only"
    },
    "lint": {
      "outputs": [],
      "outputLogs": "new-only"
    },
    "clean": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
